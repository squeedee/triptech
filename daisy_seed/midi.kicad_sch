  (text "MIDI THRU — Hard-wired from opto output"
    (exclude_from_sim no)
    (at 170.18 134.62 0)
    (effects (font (size 1.778 1.778) bold) (justify left))
    (uuid "50000000-0004-4000-8000-000000000001")
  )
  (text "Standard MIDI IN circuit per MIDI 1.0 DIN Transport spec.\n220R current-limiting on input, 1N4148 reverse-polarity\nprotection across the opto LED. 6N138 opto-isolator\nprovides galvanic isolation. 3.3V logic output."
    (exclude_from_sim no)
    (at 25.4 118.11 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid "50000000-0005-4000-8000-000000000001")
  )
  (text "33R series resistors for 3.3V MIDI current loop.\n~5mA loop current: 3.3V / (33+33+220int) = 11.5mA"
    (exclude_from_sim no)
    (at 25.4 195.58 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid "50000000-0006-4000-8000-000000000001")
  )


