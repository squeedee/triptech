	(text "USB 2.0 device mode (full-speed). CC pull-downs identify\nthis port as a USB device (UFP). D+/D- connect to Daisy\nSeed D29/D30 (STM32H750 USB_OTG_HS peripheral)."
		(exclude_from_sim no)
		(at 76.2 38.1 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left bottom)
		)
		(uuid "60000001-0002-4000-8000-000000000001")
	)
	(text "R_VBUS: DNP by default. Populate 0R to feed USB VBUS\nto +5V rail (e.g. for bus-powered operation)."
		(exclude_from_sim no)
		(at 160.02 55.88 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "60000001-0003-4000-8000-000000000001")
	)
	(text "Shield EMI filter: 1M + 4.7nF to GND"
		(exclude_from_sim no)
		(at 43.18 175.26 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left bottom)
		)
		(uuid "60000001-0004-4000-8000-000000000001")
	)
	(text "U_ESD: USBLC6-2SC6 (SOT-23-6)\nDNP — populate for ESD protection\non D+/D- lines. Connect I/O1 to USB_DP,\nI/O2 to USB_DM, VBUS to VBUS, GND to GND."
		(exclude_from_sim no)
		(at 160.02 109.22 0)
		(effects
			(font
